{
  "name": "cee-agent-bridge",
  "displayName": "CEE Agent Bridge",
  "description": "Passively warms the ShiftCore CEE Hardware Anchor Bank via the CEE CLI.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cee.groundMission",
        "title": "CEE: Ground Mission (Hardware Governance)"
      },
      {
        "command": "cee.viewReasoningTrace",
        "title": "CEE: View Hardware Reasoning Trace"
      },
      {
        "command": "cee.diffReasoningTraces",
        "title": "CEE: Diff Hardware Reasoning Paths"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "cee.groundMission",
          "group": "cee_group@1"
        },
        {
          "command": "cee.viewReasoningTrace",
          "group": "cee_group@2"
        },
        {
          "command": "cee.diffReasoningTraces",
          "group": "cee_group@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
